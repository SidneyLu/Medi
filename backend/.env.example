APP_ENV=development
SECRET_KEY=replace-before-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Existing application storage
MEDI_SQLITE_PATH=storage/medi.sqlite3
UPLOAD_DIR=storage/uploads

# PDF knowledge base
DATABASE_URL=postgresql://medi:medi@localhost:5432/medi
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=medical_chunks
KNOWLEDGE_PDF_PATH=../默克家庭医学手册.pdf
MINERU_OUTPUT_DIR=data/parsed
PDF_PREVIEW_DIR=storage/pdf_previews
PDF_PREVIEW_SCALE=1.35

# DashScope APIs
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-flash
QWEN_EMBEDDING_MODEL=qwen3-vl-embedding
QWEN_RERANK_MODEL=qwen3-rerank
# Set this to the Qwen rerank REST endpoint enabled for your DashScope account.
QWEN_RERANK_URL=
QWEN_TIMEOUT_SECONDS=45
MSD_SOURCE_BASE_URL=https://www.msdmanuals.cn/home
