# Browser → FastAPI
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001
# api | mock
NEXT_PUBLIC_API_MODE=api

# Server-side chat route → FastAPI (falls back to NEXT_PUBLIC_API_BASE_URL)
API_BASE_URL=http://127.0.0.1:8001

# DashScope OpenAI-compatible (Qwen) for Next.js /api/chat
DASHSCOPE_API_KEY=
# Alternate key name also accepted
QWEN_API_KEY=
QWEN_MODEL=qwen3.5-flash
# Optional override; default is DashScope compatible-mode endpoint
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
